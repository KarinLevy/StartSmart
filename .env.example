# Copy this file to .env and fill in your Supabase project values.
# Never commit .env — it is listed in .gitignore.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Seed scripts only (never used by the frontend) ──────────────────────────
# Get from: Supabase Dashboard → Settings → API → service_role (secret)
# Required for:  npm run seed:demo    (creates 5 demo users via Admin API)
# Optional for:  npm run seed:single  (uses anon key if this is absent)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
